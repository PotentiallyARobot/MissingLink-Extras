.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}.toast.err{border-left-color:var(--danger)}

/* LASSO */
.lasso-bar{display:flex;align-items:center;gap:8px;padding:6px 12px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);position:absolute;top:12px;left:50%;transform:translateX(-50%);z-index:20;box-shadow:0 4px 16px rgba(0,0,0,.5)}
.lasso-bar label{margin:0;font-size:.7rem}
.lasso-bar input[type="range"]{width:80px}
.lasso-wrap{position:relative;display:inline-block}
.lasso-canvas{position:absolute;top:0;left:0;cursor:crosshair;z-index:15}
.lasso-mask-preview{position:absolute;top:0;left:0;pointer-events:none;z-index:14;opacity:.45}

@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
@media(max-width:960px){.ws{grid-template-columns:300px 1fr 0}.R{display:none}}
@media(max-width:640px){.ws{grid-template-columns:1fr}.L{max-height:45vh}}
</style></head><body>
<div class="app">
<header>
  <img class="logo" src="__LOGO_SRC__" alt="ML"/>
  <div><h1>Qwen Image Edit <span class="ver">2511</span></h1><div class="tagline">Stop Compiling. <strong style="color:var(--gold)">Start Building.</strong></div></div>
  <div class="spacer"></div>
  <div class="pill" id="pill">READY</div>
</header>
<div class="ws">
<div class="L"><div class="Ls">

  <!-- IMAGES -->
  <div class="sec">
    <div class="sh"><svg viewBox="0 0 24 24"><path d="M21 19V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>Input Images</div>
    <div class="slots" id="slots"></div>
    <button class="btn bg bs" style="margin-top:8px" onclick="addSlot()">+ Add Image Slot</button>
    <input type="file" id="fi" accept="image/*" style="display:none"/>
    <p class="hint">Each slot = one input. Prompt can reference "image 1", "image 2". Drag files onto a slot or paste from clipboard.</p>
  </div>

  <!-- PROMPT -->
  <div class="sec">
    <div class="sh"><svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 000-1.41l-2.34-2.34a1 1 0 00-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>Prompt</div>
    <div class="f"><textarea id="prompt" rows="3" placeholder="Describe the edit...&#10;Reference as 'image 1', 'image 2', etc."></textarea></div>
    <div class="f"><label>Negative Prompt <span style="color:var(--text-muted);font-weight:300;text-transform:none">(required for CFG &gt; 1)</span></label>
      <textarea id="neg" rows="2" placeholder="blurry, low quality, deformed, artifacts..."></textarea></div>
  </div>

  <!-- SETTINGS -->
  <div class="sec">
    <div class="sh ct" onclick="tc(this)"><svg viewBox="0 0 24 24"><path d="M19.14 12.94a7.07 7.07 0 000-1.88l2.03-1.58a.49.49 0 00.12-.61l-1.92-3.32a.49.49 0 00-.59-.22l-2.39.96a7.04 7.04 0 00-1.62-.94l-.36-2.54A.48.48 0 0013.93 2h-3.86a.48.48 0 00-.48.41l-.36 2.54a7.04 7.04 0 00-1.62.94l-2.39-.96a.49.49 0 00-.59.22L2.71 8.87a.48.48 0 00.12.61l2.03 1.58a7.07 7.07 0 000 1.88l-2.03 1.58a.49.49 0 00-.12.61l1.92 3.32a.49.49 0 00.59.22l2.39-.96c.5.37 1.04.69 1.62.94l.36 2.54a.48.48 0 00.48.41h3.86a.48.48 0 00.48-.41l.36-2.54a7.04 7.04 0 001.62-.94l2.39.96a.49.49 0 00.59-.22l1.92-3.32a.49.49 0 00-.12-.61l-2.03-1.58zM12 15.6A3.6 3.6 0 1115.6 12 3.6 3.6 0 0112 15.6z"/></svg>Settings</div>
    <div class="cb">
      <div class="f"><label>True CFG Scale</label><div class="rr"><input type="range" id="cfg" min="1" max="10" step="0.1" value="__DEFAULT_CFG__" oninput="rv('cfgV',this.value)"/><span class="rv" id="cfgV">__DEFAULT_CFG__</span></div></div>
      <div class="f"><label>Guidance Scale <span style="color:var(--text-muted);font-weight:300;text-transform:none">(distilled only)</span></label><div class="rr"><input type="range" id="gs" min="0" max="20" step="0.5" value="1.0" oninput="rv('gsV',this.value)"/><span class="rv" id="gsV">1.0</span></div></div>
      <div class="f"><label>Steps</label><div class="rr"><input type="range" id="steps" min="1" max="50" step="1" value="__DEFAULT_STEPS__" oninput="rv('stV',this.value)"/><span class="rv" id="stV">__DEFAULT_STEPS__</span></div></div>
      <div class="f"><label>Batch</label><div class="rr"><input type="range" id="batch" min="1" max="4" step="1" value="1" oninput="rv('baV',this.value)"/><span class="rv" id="baV">1</span></div></div>
      <div class="fr"><div class="f"><label>Width (0=auto)</label><input type="number" id="w" value="0" min="0" max="4096" step="64"/></div><div class="f"><label>Height (0=auto)</label><input type="number" id="h" value="0" min="0" max="4096" step="64"/></div></div>
      <div class="fr"><div class="f"><label>Seed (-1=rand)</label><input type="number" id="seed" value="-1" min="-1"/></div><div class="f"><label>Max Seq Len</label><input type="number" id="msl" value="0" min="0" max="1024" placeholder="0=default"/></div></div>
    </div>
  </div>

  <!-- LORA -->
  <div class="sec">
    <div class="sh ct cc" onclick="tc(this)"><svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>LoRA Adapters</div>
    <div class="cb cc">
      <div id="lcs" style="margin-bottom:8px"></div>
      <div class="f"><label>Path</label><input type="text" id="lp" placeholder="user/my-lora"/></div>
      <div class="fr"><div class="f"><label>Name</label><input type="text" id="ln" placeholder="auto"/></div>
        <div class="f"><label>Weight</label><div class="rr"><input type="range" id="lw" min="0" max="2" step="0.05" value="1.0" oninput="rv('lwV',this.value)"/><span class="rv" id="lwV">1.0</span></div></div></div>
      <button class="btn bg bs bf" onclick="addLora()">Apply LoRA</button>
    </div>
  </div>

</div>
<div class="gb">
  <div style="display:flex;gap:8px">
    <button class="btn bp" style="flex:1;padding:12px;font-size:.95rem;letter-spacing:2px;position:relative;overflow:hidden" id="genBtn" onclick="gen()">&#9889; GENERATE</button>
    <button class="btn bg" style="padding:12px 18px;font-size:.95rem;display:none" id="stopBtn" onclick="stopGen()">&#9632; STOP</button>
  </div>
  <div class="gp" id="gp"><div class="gpf" id="gpf"></div></div>
  <div class="gsl" id="gsl"></div>
</div>
</div>

<div class="C" id="C">
  <!-- Lasso toolbar -->
  <div class="lasso-bar" id="lassoBar" style="display:none">
    <button class="btn bg bs" id="lassoToggle" onclick="toggleLasso()" title="Draw mask region">&#9998; Lasso</button>
    <label>Blur:</label>
    <input type="range" id="maskBlur" min="0" max="50" step="1" value="10" oninput="rv('mbV',this.value)"/>
    <span class="rv" id="mbV" style="min-width:24px">10</span>
    <button class="btn bg bs" onclick="clearMask()">Clear</button>
    <button class="btn bg bs" onclick="undoLasso()">Undo</button>
  </div>
  <div class="ce" id="ce">
    <svg viewBox="0 0 24 24"><path d="M21 19V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
    <h3>Ready to Edit</h3>
    <p>Add images to slots, write a prompt, hit Generate.<br/>Hover outputs for actions. Use the Lasso tool to mask regions.</p>
  </div>
  <div class="og" id="og" style="display:none"></div>
  <!-- Lasso drawing surface — shown over Image 1 preview -->
  <div class="lasso-wrap" id="lassoWrap" style="display:none">
    <img id="lassoImg"/>
    <canvas id="lassoMaskPreview" class="lasso-mask-preview"></canvas>
    <canvas id="lassoDraw" class="lasso-canvas"></canvas>
  </div>
</div>

<div class="R">
  <div class="rh">History</div>
  <div class="rs" id="hs"></div>
</div>
</div></div>

<div class="lb" id="lb" onclick="this.classList.remove('open')"><img id="lbi"/></div>
<div class="toast" id="toast"></div>

<script>
const $=id=>document.getElementById(id);
const rv=(id,v)=>$(id).textContent=v;
function tc(el){el.classList.toggle('cc');el.nextElementSibling.classList.toggle('cc')}
function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}

/* === SLOTS === */
const S=[];let nid=0,aSid=null;

function addSlot(du=null){const id=nid++;S.push({id,du});rS();return id}
function rmSlot(id){const i=S.findIndex(s=>s.id===id);if(i>=0)S.splice(i,1);rS()}
function setSI(id,du){const s=S.find(s=>s.id===id);if(s)s.du=du;rS()}
function clrSlot(id){setSI(id,null)}
function trigUp(id){aSid=id;$('fi').click()}
function slotIdx(id){const i=S.findIndex(s=>s.id===id);return i>=0?i+1:'?'}

$('fi').addEventListener('change',e=>{
  const f=e.target.files[0];if(!f||aSid===null)return;
  rdF(f,aSid);e.target.value='';
});
function rdF(file,sid){const r=new FileReader();r.onload=ev=>setSI(sid,ev.target.result);r.readAsDataURL(file)}

function rS(){
  const c=$('slots');c.innerHTML='';
  S.forEach((s,idx)=>{
    const d=document.createElement('div');
    d.className='slot'+(s.du?' has':'');d.dataset.sid=s.id;
    if(s.du){
      d.innerHTML=`<img class="pv" src="${s.du}"/><div class="sbar"><span class="slbl">Image ${idx+1}</span><div class="sp"></div><button class="sb" title="Replace image" onclick="event.stopPropagation();trigUp(${s.id})">&#8635;</button><button class="sb" title="Clear" onclick="event.stopPropagation();clrSlot(${s.id})">&#8999;</button><button class="sb dng" title="Remove slot" onclick="event.stopPropagation();rmSlot(${s.id})">&#215;</button></div>`;
    } else {
      d.onclick=()=>trigUp(s.id);
      d.innerHTML=`<div class="sbar"><span class="slbl">Image ${idx+1}</span><div class="sp"></div><button class="sb dng" title="Remove" onclick="event.stopPropagation();rmSlot(${s.id})">&#215;</button></div><div class="ph"><svg viewBox="0 0 24 24"><path d="M19 7v2.99s-1.99.01-2 0V7h-3s.01-1.99 0-2h3V2h2v3h3v2h-3zm-3 4V8h-3V5H5a2 2 0 00-2 2v12a2 2 0 002 2h12a2 2 0 002-2v-8h-3zM5 19l3-4 2 3 3-4 4 5H5z"/></svg>Click to upload or drop file here</div>`;
    }
    d.addEventListener('dragover',e=>{e.preventDefault();d.style.borderColor='var(--gold)'});
    d.addEventListener('dragleave',()=>d.style.borderColor='');
    d.addEventListener('drop',e=>{e.preventDefault();d.style.borderColor='';const f=e.dataTransfer.files[0];if(f&&f.type.startsWith('image/'))rdF(f,s.id)});
    c.appendChild(d);
  });
}
addSlot();addSlot();

/* === GENERATE === */
let polling=false;
async function gen(){
  const filled=S.filter(s=>s.du);
  if(!filled.length){toast('Upload at least one image',1);return}
  const p=$('prompt').value.trim();if(!p){toast('Enter a prompt',1);return}
  const imgs={};S.forEach((s,i)=>{if(s.du)imgs[String(i)]=s.du});
  const imgCount=Object.keys(imgs).length;
  console.log('Sending',imgCount,'images to /api/generate');
  const params={images:imgs,prompt:p,negative_prompt:$('neg').value.trim(),
    true_cfg_scale:parseFloat($('cfg').value),guidance_scale:parseFloat($('gs').value),
    num_inference_steps:parseInt($('steps').value),num_images_per_prompt:parseInt($('batch').value),
    width:parseInt($('w').value)||null,height:parseInt($('h').value)||null,
    seed:parseInt($('seed').value),max_sequence_length:parseInt($('msl').value)||null,
    mask:maskDataUrl||null,mask_blur:parseInt($('maskBlur').value)||0};
  setG(1);
  try{const d=await(await fetch('/api/generate',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(params)})).json();if(!d.ok)throw new Error(d.error);poll()}catch(e){toast(e.message,1);setG(0)}
}
function setG(on){
  $('genBtn').disabled=on;$('genBtn').innerHTML=on?'&#9203; GENERATING...':'&#9889; GENERATE';
  $('stopBtn').style.display=on?'block':'none';$('stopBtn').disabled=false;$('stopBtn').textContent='■ STOP';
  $('gp').style.display=on?'block':'none';$('gsl').style.display=on?'block':'none';$('gpf').style.width='0%';
  $('pill').textContent=on?'RUNNING':'READY';$('pill').className='pill'+(on?' run':'');
}
async function stopGen(){
  try{
    $('stopBtn').disabled=true;$('stopBtn').textContent='Stopping...';
    await fetch('/api/stop',{method:'POST'});
    toast('Stopping after current step...');
  }catch(e){toast(e.message,1)}
}
function poll(){
  if(polling)return;polling=true;
  (async function lp(){
    try{const d=await(await fetch('/api/status')).json();
      $('gpf').style.width=d.progress+'%';$('gsl').textContent=d.message||'';
      $('pill').textContent=d.running?(d.message||'RUNNING'):'READY';
      if(d.running){setTimeout(lp,800);return}
      polling=false;
      if(d.error){toast(d.error,1);setG(0);return}
      if(d.results?.length){showR(d.results);setG(0);rH();return}
      setG(0);
    }catch(e){setTimeout(lp,2000)}
  })();
}

function showR(results){
  // Exit lasso mode to show results
  if(lassoActive){lassoActive=false;$('lassoToggle').style.background='';$('lassoToggle').style.color=''}
  $('lassoWrap').style.display='none';
  $('ce').style.display='none';const g=$('og');g.style.display='flex';g.innerHTML='';
  results.forEach((b64,i)=>{
    const c=document.createElement('div');c.className='oc';c.dataset.b64=b64;
    // Build per-slot "Use as Image N" buttons
    let sbtns=S.map((s,si)=>`<button class="btn bg bs" onclick="event.stopPropagation();s2s(${i},${s.id})" title="Replace the contents of Image ${si+1} with this output">Use as Image ${si+1}</button>`).join('');
    c.innerHTML=`<img src="${b64}" onclick="$('lbi').src=this.src;$('lb').classList.add('open')"/>
      <div class="ca">
        <button class="btn bg bs" onclick="event.stopPropagation();dl(${i})">&#11015; Save</button>
        <button class="btn bg bs" onclick="event.stopPropagation();s2n(${i})" title="Add this output as a new image slot">+ New Slot</button>
        ${sbtns}
      </div>`;
    g.appendChild(c);
  });
}
function dl(i){const c=$('og').children[i];if(!c)return;const a=document.createElement('a');a.href=c.dataset.b64;a.download='ml_output_'+i+'.png';a.click()}
function s2s(oi,sid){const c=$('og').children[oi];if(!c)return;setSI(sid,c.dataset.b64);toast('Set as Image '+slotIdx(sid))}
function s2n(oi){const c=$('og').children[oi];if(!c)return;const id=addSlot(c.dataset.b64);toast('Added as Image '+slotIdx(id))}

/* === HISTORY === */
async function rH(){
  try{const d=await(await fetch('/api/history')).json();const s=$('hs');s.innerHTML='';
  (d.history||[]).forEach(h=>{const div=document.createElement('div');div.className='hi';
    div.onclick=e=>{if(e.target.closest('.hdel'))return;lH(h)};
    const inTh=(h.input_thumbs||[]).map(o=>'<img src="'+o+'" style="border-color:var(--gold-dim)"/>').join('');
    const outTh=(h.outputs||[]).slice(0,3).map(o=>'<img src="'+o+'"/>').join('');
    div.innerHTML='<button class="hdel" onclick="event.stopPropagation();delH(\''+h.id+'\')" title="Delete">&#215;</button>'
      +'<div class="ht">'+h.timestamp+'</div><div class="hp">'+esc(h.prompt)+'</div>'
      +'<div class="hth">'+inTh+(inTh&&outTh?' <span style="color:var(--text-muted);font-size:.6rem;margin:0 2px">→</span> ':'')+outTh+'</div>';
    s.appendChild(div)})}catch(e){}
}
async function delH(id){
  try{await fetch('/api/history/delete',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id})});rH();toast('Removed')}catch(e){}
}
async function lH(h){
  $('prompt').value=h.prompt||'';$('neg').value=h.negative_prompt||'';
  const p=h.params||{};
  if(p.true_cfg_scale!=null){$('cfg').value=p.true_cfg_scale;rv('cfgV',p.true_cfg_scale)}
  if(p.num_inference_steps!=null){$('steps').value=p.num_inference_steps;rv('stV',p.num_inference_steps)}
  if(p.seed!=null)$('seed').value=p.seed;
  if(p.guidance_scale!=null){$('gs').value=p.guidance_scale;rv('gsV',p.guidance_scale)}
  if(p.num_images_per_prompt!=null){$('batch').value=p.num_images_per_prompt;rv('baV',p.num_images_per_prompt)}
  // Fetch full entry to get input_images
  try{
    const d=await(await fetch('/api/history/entry?id='+encodeURIComponent(h.id))).json();
    const imgs=(d.entry&&d.entry.input_images)||[];
    if(imgs.length){
      S.length=0;nid=0;
      imgs.forEach(du=>addSlot(du));
      rS();
    }
  }catch(e){console.warn('Could not load input images:',e)}
  if(h.outputs?.length)showR(h.outputs);
  toast('Loaded — inputs, prompt & settings restored');
}

/* === LORA === */
async function addLora(){
  const p=$('lp').value.trim();if(!p){toast('Enter path',1);return}
  const n=$('ln').value.trim()||null,w=parseFloat($('lw').value);toast('Loading LoRA...');
  try{const d=await(await fetch('/api/lora/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({path:p,name:n,weight:w})})).json();
    if(!d.ok)throw new Error(d.error);toast(d.message);rL();$('lp').value='';$('ln').value=''}catch(e){toast(e.message,1)}
}
async function removeLora(n){
  try{const d=await(await fetch('/api/lora/remove',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:n})})).json();
    if(!d.ok)throw new Error(d.error);toast(d.message);rL()}catch(e){toast(e.message,1)}
}
async function rL(){
  try{const d=await(await fetch('/api/lora/list')).json();const c=$('lcs');c.innerHTML='';
    for(const[n,w]of Object.entries(d.loras||{}))c.innerHTML+=`<span class="lc">${esc(n)} <span class="lw">${w}</span><button onclick="removeLora('${esc(n)}')">&#215;</button></span>`}catch(e){}
}

function toast(m,e){const t=$('toast');t.textContent=m;t.className='toast show'+(e?' err':'');clearTimeout(t._t);t._t=setTimeout(()=>t.className='toast',3500)}

/* === LASSO MASK TOOL === */
let lassoActive=false, lassoDrawing=false;
let lassoPolygons=[];  // array of arrays of {x,y}
let currentPoly=[];
let maskDataUrl=null;

function toggleLasso(){
  // Need at least one image loaded
  const first=S.find(s=>s.du);
  if(!first){toast('Upload an image first',1);return}
  lassoActive=!lassoActive;
  $('lassoToggle').style.background=lassoActive?'var(--gold)':'';
  $('lassoToggle').style.color=lassoActive?'#0a0a0a':'';
  if(lassoActive){
    showLassoCanvas(first.du);
  } else {
    $('lassoWrap').style.display='none';
    // Show outputs/empty again
    const hasOutputs=$('og').children.length>0;
    $('og').style.display=hasOutputs?'flex':'none';
    $('ce').style.display=hasOutputs?'none':'';
  }
}

function showLassoCanvas(imgSrc){
  $('ce').style.display='none';
  $('og').style.display='none';
  const wrap=$('lassoWrap');wrap.style.display='block';
  const img=$('lassoImg');
  img.onload=()=>{
    const maxW=$('C').clientWidth-48, maxH=$('C').clientHeight-80;
    let w=img.naturalWidth, h=img.naturalHeight;
    const scale=Math.min(1,maxW/w,maxH/h);
    w=Math.round(w*scale);h=Math.round(h*scale);
    img.style.width=w+'px';img.style.height=h+'px';
    // Size canvases
    const dc=$('lassoDraw');dc.width=w;dc.height=h;dc.style.width=w+'px';dc.style.height=h+'px';
    const mp=$('lassoMaskPreview');mp.width=w;mp.height=h;mp.style.width=w+'px';mp.style.height=h+'px';
    renderMaskPreview();
  };
  img.src=imgSrc;
}

// Drawing handlers on the lasso canvas
(function(){
  const dc=$('lassoDraw');
  dc.addEventListener('mousedown',e=>{if(!lassoActive)return;lassoDrawing=true;currentPoly=[pt(e)];drawLive()});
  dc.addEventListener('mousemove',e=>{if(!lassoDrawing)return;currentPoly.push(pt(e));drawLive()});
  dc.addEventListener('mouseup',()=>{if(!lassoDrawing)return;lassoDrawing=false;if(currentPoly.length>2){lassoPolygons.push([...currentPoly])}currentPoly=[];renderMaskPreview();drawLive()});
  dc.addEventListener('mouseleave',()=>{if(!lassoDrawing)return;lassoDrawing=false;if(currentPoly.length>2){lassoPolygons.push([...currentPoly])}currentPoly=[];renderMaskPreview();drawLive()});
  // Touch
  dc.addEventListener('touchstart',e=>{if(!lassoActive)return;e.preventDefault();lassoDrawing=true;currentPoly=[pt(e.touches[0])];drawLive()},{passive:false});
  dc.addEventListener('touchmove',e=>{if(!lassoDrawing)return;e.preventDefault();currentPoly.push(pt(e.touches[0]));drawLive()},{passive:false});
  dc.addEventListener('touchend',()=>{if(!lassoDrawing)return;lassoDrawing=false;if(currentPoly.length>2){lassoPolygons.push([...currentPoly])}currentPoly=[];renderMaskPreview();drawLive()});

  function pt(e){const r=dc.getBoundingClientRect();return{x:e.clientX-r.left,y:e.clientY-r.top}}
})();

function drawLive(){
  const dc=$('lassoDraw'),ctx=dc.getContext('2d');
  ctx.clearRect(0,0,dc.width,dc.height);
  // Draw existing polygons as filled translucent gold
  ctx.fillStyle='rgba(212,160,23,0.25)';ctx.strokeStyle='var(--gold)';ctx.lineWidth=2;
  lassoPolygons.forEach(poly=>{
    ctx.beginPath();poly.forEach((p,i)=>i===0?ctx.moveTo(p.x,p.y):ctx.lineTo(p.x,p.y));ctx.closePath();ctx.fill();ctx.stroke();
  });
  // Draw current polygon being drawn
  if(currentPoly.length>1){
    ctx.beginPath();ctx.strokeStyle='#f0c840';ctx.lineWidth=2;ctx.setLineDash([4,4]);
    currentPoly.forEach((p,i)=>i===0?ctx.moveTo(p.x,p.y):ctx.lineTo(p.x,p.y));
    ctx.stroke();ctx.setLineDash([]);
  }
}

function renderMaskPreview(){
  // Draw the mask preview (red/gold overlay showing selected region)
  const mp=$('lassoMaskPreview'),ctx=mp.getContext('2d');
  ctx.clearRect(0,0,mp.width,mp.height);
  if(!lassoPolygons.length){maskDataUrl=null;return}
  ctx.fillStyle='rgba(212,160,23,0.35)';
  lassoPolygons.forEach(poly=>{
    ctx.beginPath();poly.forEach((p,i)=>i===0?ctx.moveTo(p.x,p.y):ctx.lineTo(p.x,p.y));ctx.closePath();ctx.fill();
  });
  // Generate the actual B&W mask at original image resolution for the backend
  buildMaskDataUrl();
}

function buildMaskDataUrl(){
  const first=S.find(s=>s.du);if(!first||!first.du)return;
  // We need original image dimensions
  const tmpImg=new Image();
  tmpImg.onload=()=>{
    const oc=document.createElement('canvas');oc.width=tmpImg.naturalWidth;oc.height=tmpImg.naturalHeight;
    const octx=oc.getContext('2d');
    // Black background (keep original)
    octx.fillStyle='#000';octx.fillRect(0,0,oc.width,oc.height);
    // White fill for selected regions (edit here)
    octx.fillStyle='#fff';
    const dc=$('lassoDraw');
    const sx=oc.width/dc.width, sy=oc.height/dc.height;
    lassoPolygons.forEach(poly=>{
      octx.beginPath();
      poly.forEach((p,i)=>i===0?octx.moveTo(p.x*sx,p.y*sy):octx.lineTo(p.x*sx,p.y*sy));
      octx.closePath();octx.fill();
    });
    maskDataUrl=oc.toDataURL('image/png');
  };
  tmpImg.src=first.du;
}

