def load_pipeline():
    global PIPELINE, TRANSFORMER

    # Scheduler — standard (NOT Lightning) config for QuantFunc 2511
    # No shift overrides — let the pipeline use its defaults
    scheduler_config = {
        "base_image_seq_len": 256,
        "base_shift": math.log(3),
        "invert_sigmas": False,
        "max_image_seq_len": 8192,
        "max_shift": math.log(3),
        "num_train_timesteps": 1000,
        "shift": 1.0,
        "shift_terminal": None,
        "stochastic_sampling": False,
        "time_shift_type": "exponential",
        "use_beta_sigmas": False,
        "use_dynamic_shifting": True,
        "use_exponential_sigmas": False,
        "use_karras_sigmas": False,
    }
    scheduler = FlowMatchEulerDiscreteScheduler.from_config(scheduler_config)

    if torch.cuda.is_available():
        torch.cuda.empty_cache()

    # --- Load transformer: local dir -> HF fallback ---
    transformer_src = None
    if LOCAL_TR_DIR and os.path.isdir(LOCAL_TR_DIR):
        print(f"  Loading transformer from local: {LOCAL_TR_DIR}")
        TRANSFORMER = NunchakuQwenImageTransformer2DModel.from_pretrained(LOCAL_TR_DIR)
        transformer_src = f"local: {LOCAL_TR_DIR}"
    else:
        precision = get_precision()
        if "int4" in precision:
            precision = "int4"
        elif "fp4" in precision:
            precision = "fp4"
        variant_by_rank = {32: "ultimate_speed", 128: "balance", 256: "best_quality"}
        variant = variant_by_rank.get(RANK, "ultimate_speed")
        hf_path = (
            f"QuantFunc/Nunchaku-Qwen-Image-EDIT-2511/"
            f"nunchaku_qwen_image_edit_2511_{variant}_{precision}.safetensors"
        )
        print(f"  Loading transformer from HF: {hf_path}")
        TRANSFORMER = NunchakuQwenImageTransformer2DModel.from_pretrained(hf_path)
        transformer_src = f"hf: {hf_path}"

    print("  Loading pipeline: Qwen/Qwen-Image-Edit-2511")
    PIPELINE = QwenImageEditPlusPipeline.from_pretrained(
        "Qwen/Qwen-Image-Edit-2511",
        transformer=TRANSFORMER,
        scheduler=scheduler,
        torch_dtype=torch.bfloat16,
    )

    gpu_mem = get_gpu_memory()
    if gpu_mem > 18:
        print(f"  GPU: {gpu_mem:.1f}GB — model CPU offload")
        PIPELINE.enable_model_cpu_offload()
    else:
        print(f"  GPU: {gpu_mem:.1f}GB — sequential CPU offload")
        TRANSFORMER.set_offload(True, use_pin_memory=False, num_blocks_on_gpu=1)
        PIPELINE._exclude_from_cpu_offload.append("transformer")
        PIPELINE.enable_sequential_cpu_offload()

    print(f"  ✅ Pipeline ready | transformer: {transformer_src}")
    return True


# ---------------------------------------------------------------------------
# LoRA
# ---------------------------------------------------------------------------
def apply_lora(lora_path, weight=1.0, adapter_name=None):
    global LOADED_LORAS
    if not PIPELINE: return False, "Pipeline not loaded"
    name = adapter_name or Path(lora_path).stem
    try:
        PIPELINE.load_lora_weights(lora_path, adapter_name=name)
        LOADED_LORAS[name] = weight
        if LOADED_LORAS:
            PIPELINE.set_adapters(list(LOADED_LORAS.keys()), list(LOADED_LORAS.values()))
        return True, f"LoRA '{name}' loaded @ {weight}"
    except Exception as e: return False, str(e)

def remove_lora(adapter_name):
    global LOADED_LORAS
    if not PIPELINE: return False, "Pipeline not loaded"
    try:
        PIPELINE.delete_adapters([adapter_name])
        LOADED_LORAS.pop(adapter_name, None)
        if LOADED_LORAS:
            PIPELINE.set_adapters(list(LOADED_LORAS.keys()), list(LOADED_LORAS.values()))
        return True, f"Removed '{adapter_name}'"
    except Exception as e: return False, str(e)


