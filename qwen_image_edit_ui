# Helpers
# ---------------------------------------------------------------------------
def img_to_b64_thumb(img, sz=128):
    t = img.copy(); t.thumbnail((sz, sz))
    buf = io.BytesIO(); t.save(buf, format="JPEG", quality=60)
    return "data:image/jpeg;base64," + base64.b64encode(buf.getvalue()).decode()

def img_to_b64(img):
    buf = io.BytesIO(); img.save(buf, format="PNG")
    return "data:image/png;base64," + base64.b64encode(buf.getvalue()).decode()


# ---------------------------------------------------------------------------
# Generation
# ---------------------------------------------------------------------------
def run_generation(params):
    global GENERATION_STATUS, HISTORY, INTERRUPT_FLAG
    INTERRUPT_FLAG = False
    GENERATION_STATUS = {"running": True, "progress": 0, "step": 0, "total_steps": 0, "message": "Preparing...", "results": [], "error": None}
    try:
        images_dict = params.get("images", {})
        images, input_thumbs = [], []
        for key in sorted(images_dict.keys(), key=lambda k: int(k)):
            d = images_dict[key]
            if not d: continue
            if d.startswith("data:"):
                _, b = d.split(",", 1)
                img = Image.open(io.BytesIO(base64.b64decode(b))).convert("RGB")
            elif d.startswith("http"):
                img = load_image(d).convert("RGB")
            else:
                img = Image.open(d).convert("RGB")
            images.append(img)
            input_thumbs.append(img_to_b64_thumb(img))

        if not images:
            GENERATION_STATUS = {**GENERATION_STATUS, "running": False, "error": "Upload at least one image."}
            return

        print(f"  🖼️  Images received: {len(images)} | Sizes: {[img.size for img in images]}")
        GENERATION_STATUS["message"] = f"Loaded {len(images)} image(s)..."

        steps = params.get("num_inference_steps", DEFAULT_STEPS)
        GENERATION_STATUS["total_steps"] = steps
        GENERATION_STATUS["message"] = "Running inference..."

        pipe_kwargs = {
            "image": images if len(images) > 1 else images[0],
            "prompt": params.get("prompt", ""),
            "num_inference_steps": steps,
            "true_cfg_scale": params.get("true_cfg_scale", DEFAULT_TRUE_CFG),
            "num_images_per_prompt": params.get("num_images_per_prompt", 1),
        }

        # Negative prompt — required for true CFG to work
        neg = params.get("negative_prompt", "").strip()
        if neg or pipe_kwargs["true_cfg_scale"] > 1.0:
            pipe_kwargs["negative_prompt"] = neg if neg else " "

        if params.get("guidance_scale") is not None:
            pipe_kwargs["guidance_scale"] = params["guidance_scale"]
        if params.get("height") and params["height"] > 0:
            pipe_kwargs["height"] = params["height"]
        if params.get("width") and params["width"] > 0:
            pipe_kwargs["width"] = params["width"]
        if params.get("max_sequence_length") and params["max_sequence_length"] > 0:
            pipe_kwargs["max_sequence_length"] = params["max_sequence_length"]
        seed = params.get("seed", -1)
        if seed >= 0:
            pipe_kwargs["generator"] = torch.Generator().manual_seed(seed)

        def step_cb(pipe, step, timestep, cb_kwargs):
            GENERATION_STATUS["step"] = step + 1
            GENERATION_STATUS["progress"] = int(((step + 1) / steps) * 100)
            GENERATION_STATUS["message"] = f"Step {step+1}/{steps}"
            if INTERRUPT_FLAG:
                pipe._interrupt = True
                GENERATION_STATUS["message"] = "Stopping..."
            return cb_kwargs
        pipe_kwargs["callback_on_step_end"] = step_cb

        img_param = pipe_kwargs["image"]
        if isinstance(img_param, list):
            print(f"  📤 Passing {len(img_param)} images to pipeline")
        else:
            print(f"  📤 Passing 1 image to pipeline ({img_param.size})")

        output = PIPELINE(**pipe_kwargs)

        # Check if interrupted
        if INTERRUPT_FLAG:
            INTERRUPT_FLAG = False
            GENERATION_STATUS = {"running": False, "progress": 0, "step": 0, "total_steps": 0, "message": "", "results": [], "error": "Generation stopped by user."}
            return

        results = []
        # If a mask was provided, composite output with original using the mask
        mask_data = params.get("mask")
        blur_radius = params.get("mask_blur", 0)
        if mask_data and images:
            from PIL import ImageFilter
            # Decode mask (white = edit region, black = keep original)
            if mask_data.startswith("data:"):
                _, mb = mask_data.split(",", 1)
            else:
                mb = mask_data
            mask_img = Image.open(io.BytesIO(base64.b64decode(mb))).convert("L")
            original = images[0]  # composite against first input image
            for out_img in output.images:
                # Resize mask to match output size
                m = mask_img.resize(out_img.size, Image.LANCZOS)
                if blur_radius > 0:
                    m = m.filter(ImageFilter.GaussianBlur(radius=blur_radius))
                # Composite: where mask is white use output, where black use original
                orig_resized = original.resize(out_img.size, Image.LANCZOS)
                composited = Image.composite(out_img, orig_resized, m)
                results.append(img_to_b64(composited))
                composited.save(str(OUTPUT_DIR / f"output_{uuid.uuid4().hex[:8]}.png"))
        else:
            for out_img in output.images:
                results.append(img_to_b64(out_img))
                out_img.save(str(OUTPUT_DIR / f"output_{uuid.uuid4().hex[:8]}.png"))

        # Store full input images so history can reload them into slots
        input_full = []
        for img in images:
            input_full.append(img_to_b64(img))

        HISTORY.insert(0, {
            "id": uuid.uuid4().hex[:8], "prompt": params.get("prompt", ""),
            "negative_prompt": neg,
            "params": {k: v for k, v in params.items() if k != "images"},
            "input_thumbs": input_thumbs, "input_images": input_full,
            "outputs": results,
            "timestamp": time.strftime("%H:%M:%S"),
        })
        if len(HISTORY) > 50: HISTORY[:] = HISTORY[:50]

        GENERATION_STATUS = {"running": False, "progress": 100, "step": steps, "total_steps": steps, "message": "Done!", "results": results, "error": None}
    except Exception as e:
        traceback.print_exc()
        GENERATION_STATUS = {"running": False, "progress": 0, "step": 0, "total_steps": 0, "message": "", "results": [], "error": str(e)}
    finally:
        gc.collect()
        if torch.cuda.is_available(): torch.cuda.empty_cache()


