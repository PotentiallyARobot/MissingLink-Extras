class Handler(BaseHTTPRequestHandler):
    def log_message(self,*a):pass
    def _j(self,d,s=200):
        b=json.dumps(d).encode();self.send_response(s)
        self.send_header("Content-Type","application/json");self.send_header("Content-Length",len(b));self.send_header("Access-Control-Allow-Origin","*");self.end_headers();self.wfile.write(b)
    def _h(self,h):
        b=h.encode();self.send_response(200);self.send_header("Content-Type","text/html;charset=utf-8");self.send_header("Content-Length",len(b));self.end_headers();self.wfile.write(b)
    def _b(self):return self.rfile.read(int(self.headers.get("Content-Length",0)))
    def do_OPTIONS(self):
        self.send_response(204)
        for k,v in[("Access-Control-Allow-Origin","*"),("Access-Control-Allow-Methods","GET,POST,OPTIONS"),("Access-Control-Allow-Headers","Content-Type")]:self.send_header(k,v)
        self.end_headers()
    def do_GET(self):
        p=urlparse(self.path).path
        if p=="/api/status":self._j(GENERATION_STATUS)
        elif p=="/api/lora/list":self._j({"loras":LOADED_LORAS})
        elif p=="/api/history":
            # Send slim version — thumbs only, no full input_images (too large)
            slim = []
            for h in HISTORY[:30]:
                entry = {k: v for k, v in h.items() if k != "input_images"}
                slim.append(entry)
            self._j({"history": slim})
        elif p=="/api/history/entry":
            # Full entry with input_images for loading into slots
            qid = parse_qs(urlparse(self.path).query).get("id", [None])[0]
            entry = next((h for h in HISTORY if h.get("id") == qid), None)
            self._j({"entry": entry} if entry else {"entry": None})
        else:
            lb=get_logo_b64();ls=f"data:image/png;base64,{lb}" if lb else LOGO_URL
            html=HTML_PAGE.replace("__LOGO_SRC__",ls).replace("__DEFAULT_CFG__",str(DEFAULT_TRUE_CFG)).replace("__DEFAULT_STEPS__",str(DEFAULT_STEPS))
            self._h(html)
    def do_POST(self):
        p=urlparse(self.path).path
        if p=="/api/generate":
            if GENERATION_STATUS.get("running"):self._j({"ok":False,"error":"Already running"});return
            try:
                params=json.loads(self._b());threading.Thread(target=run_generation,args=(params,),daemon=True).start();self._j({"ok":True})
            except Exception as e:self._j({"ok":False,"error":str(e)})
        elif p=="/api/stop":
            global INTERRUPT_FLAG
            if GENERATION_STATUS.get("running"):
                INTERRUPT_FLAG=True;self._j({"ok":True,"message":"Stopping after current step..."})
            else:
                self._j({"ok":False,"error":"Nothing running"})
        elif p=="/api/lora/add":
            try:
                d=json.loads(self._b());ok,msg=apply_lora(d["path"],d.get("weight",1.0),d.get("name"));self._j({"ok":ok,"message":msg,"error":None if ok else msg})
            except Exception as e:self._j({"ok":False,"error":str(e)})
        elif p=="/api/lora/remove":
            try:
                d=json.loads(self._b());ok,msg=remove_lora(d["name"]);self._j({"ok":ok,"message":msg,"error":None if ok else msg})
            except Exception as e:self._j({"ok":False,"error":str(e)})
        elif p=="/api/history/delete":
            try:
                d=json.loads(self._b());hid=d.get("id")
                HISTORY[:] = [h for h in HISTORY if h.get("id") != hid]
                self._j({"ok":True})
            except Exception as e:self._j({"ok":False,"error":str(e)})
        else:self._j({"error":"Not found"},404)

def start_server(port=7860):
    srv=HTTPServer(("0.0.0.0",port),Handler);threading.Thread(target=srv.serve_forever,daemon=True).start()
    print(f"\n✅ Server on port {port}");return srv

